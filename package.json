{
  "name": "@miaskiewicz/turbo-test",
  "version": "0.1.0",
  "description": "A blazing-fast test runner — 5x faster than vitest. A drop-in replacement for vitest.",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
