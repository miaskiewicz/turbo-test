{
  "name": "@miaskiewicz/turbo-test",
  "version": "0.3.7",
  "description": "A blazing-fast native test runner — a drop-in replacement for vitest, ~5-12x faster vs jsdom. Rust + V8, oxc transform, all-Rust DOM (rtdom), native V8 coverage.",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "turbo-test": "cli.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    },
    "./globals": {
      "types": "./types/globals.d.ts"
    },
    "./types/vitest.d.ts": "./types/vitest.d.ts",
    "./types/jest-globals.d.ts": "./types/jest-globals.d.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "cli.js",
    "index.js",
    "index.d.ts",
    "types/",
    "bin/turbo-test-*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bash scripts/npm-build.sh",
    "test": "node --test 'test/*.mjs'",
    "prepublishOnly": "bash scripts/npm-build.sh"
  },
  "keywords": [
    "test",
    "test-runner",
    "testing",
    "vitest",
    "jest",
    "fast",
    "native",
    "rust",
    "v8",
    "drop-in"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miaskiewicz/turbo-test.git"
  },
  "homepage": "https://github.com/miaskiewicz/turbo-test#readme",
  "bugs": {
    "url": "https://github.com/miaskiewicz/turbo-test/issues"
  },
  "author": "miaskiewicz",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "esbuild": "^0.21.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
